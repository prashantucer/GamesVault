# ── Frontend (Vercel) ──────────────────────────────────────────────
# Razorpay public key — safe to expose in browser
VITE_RAZORPAY_KEY_ID=rzp_test_your_key_id_here

# Render backend URL — set this on Vercel dashboard after deploying server to Render
# Example: https://gamevault-api.onrender.com
VITE_API_URL=https://your-app-name.onrender.com

# ── Backend (Render / local server) ───────────────────────────────
# Razorpay secret keys — NEVER commit these, add via Render dashboard
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_secret_key_here
PORT=5000
