# Copy this file to .env and fill in your Razorpay test keys
# Get from: https://dashboard.razorpay.com → Settings → API Keys

# Frontend (public key - safe to expose)
VITE_RAZORPAY_KEY_ID=rzp_test_your_key_id_here

# Backend (kept secret - add to Vercel Environment Variables, never commit)
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_secret_key_here
